{
  "family": "neyya-web",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::008582147209:role/neyya-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::008582147209:role/neyya-web-task-role",
  "containerDefinitions": [
    {
      "name": "web",
      "image": "008582147209.dkr.ecr.eu-west-1.amazonaws.com/neyya-web:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3001,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "3001" },
        { "name": "HOSTNAME", "value": "0.0.0.0" },
        { "name": "NEXT_PUBLIC_API_URL", "value": "https://api.neyya.ai" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/neyya-web",
          "awslogs-region": "eu-west-1",
          "awslogs-stream-prefix": "web"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "wget -qO- http://localhost:3001/ || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      }
    }
  ]
}
