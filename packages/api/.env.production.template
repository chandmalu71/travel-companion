# ═══════════════════════════════════════════════════════════════════════════════
# Neyya.ai — Production Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this to .env.production and fill in real values.
# NEVER commit .env.production to git.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Database (Neon Serverless PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgresql://neondb_owner:PASSWORD@ep-XXXXX.eu-west-1.aws.neon.tech/neondb?sslmode=require

# ─── Redis (Upstash Serverless Redis) ────────────────────────────────────────
REDIS_URL=rediss://default:PASSWORD@eu1-XXXXX.upstash.io:6379

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=GENERATE_A_RANDOM_64_CHARACTER_STRING_HERE
NODE_ENV=production

# ─── OAuth ────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx
MICROSOFT_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MICROSOFT_CLIENT_SECRET=xxxxx
FACEBOOK_APP_ID=xxxxx
FACEBOOK_APP_SECRET=xxxxx

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ─── Email (AWS SES) ─────────────────────────────────────────────────────────
EMAIL_PROVIDER=ses
SES_REGION=eu-west-1
SES_FROM_ADDRESS=noreply@neyya.ai

# ─── Storage (AWS S3) ────────────────────────────────────────────────────────
S3_BUCKET=neyya-uploads
S3_REGION=eu-west-1

# ─── Encryption ───────────────────────────────────────────────────────────────
PII_ENCRYPTION_KEY=GENERATE_A_32_BYTE_HEX_STRING_HERE

# ─── URLs ─────────────────────────────────────────────────────────────────────
APP_URL=https://neyya.ai
ADMIN_URL=https://admin.neyya.ai
API_URL=https://api.neyya.ai

# ─── Optional: Weather ────────────────────────────────────────────────────────
OPENWEATHERMAP_API_KEY=xxxxx

# ─── Optional: AI (AWS Bedrock) ───────────────────────────────────────────────
BEDROCK_REGION=eu-west-1
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
