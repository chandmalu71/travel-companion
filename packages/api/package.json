{
  "name": "@travel-companion/api",
  "version": "0.1.0",
  "private": true,
  "description": "Fastify API server for Travel Companion",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1089.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.1089.0",
    "@aws-sdk/client-comprehend": "^3.1089.0",
    "@aws-sdk/client-s3": "^3.1090.0",
    "@aws-sdk/client-ses": "^3.1089.0",
    "@aws-sdk/client-sqs": "^3.1089.0",
    "@aws-sdk/client-textract": "^3.1090.0",
    "@aws-sdk/s3-request-presigner": "^3.1090.0",
    "@fastify/cors": "^10.0.2",
    "@fastify/env": "^5.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.2.1",
    "@travel-companion/shared": "workspace:*",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "imapflow": "^1.4.7",
    "ioredis": "^5.4.2",
    "jose": "^6.2.3",
    "kysely": "^0.27.5",
    "pg": "^8.13.1",
    "socket.io": "^4.8.3",
    "stripe": "^22.3.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "fast-check": "^4.9.0",
    "pino-pretty": "^13.1.3",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.0"
  }
}
