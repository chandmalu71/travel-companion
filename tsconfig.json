{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "exactOptionalPropertyTypes": false,
    "paths": {
      "@travel-companion/shared": ["./packages/shared/src"],
      "@travel-companion/shared/*": ["./packages/shared/src/*"],
      "@travel-companion/api": ["./packages/api/src"],
      "@travel-companion/api/*": ["./packages/api/src/*"],
      "@travel-companion/web": ["./packages/web/src"],
      "@travel-companion/web/*": ["./packages/web/src/*"],
      "@travel-companion/mobile": ["./packages/mobile/src"],
      "@travel-companion/mobile/*": ["./packages/mobile/src/*"]
    },
    "baseUrl": "."
  },
  "exclude": ["node_modules", "**/node_modules", "**/dist", "**/build", "**/.next"]
}
