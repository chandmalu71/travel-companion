!**/.env.example

# Docker
docker-compose.yml
Dockerfile

# Documentation
docs/
*.md
!packages/*/README.md

# Tests
**/__tests__
**/*.test.ts
**/*.spec.ts
**/coverage
**/playwright-report

# OS
.DS_Store
Thumbs.db

# Infrastructure (not needed in images)
infrastructure/
.github/
scripts/

# Prototype
prototype/
